# ui.tutorial.*
msgid "ui.tutorial.welcome"
msgstr "Welcome to Aftermap. Your shelter is your home — every day brings a choice."

msgid "ui.tutorial.resources"
msgstr "Watch the resource bar: food, water, fuel, and morale are consumed each day."

msgid "ui.tutorial.facility"
msgstr "Build facilities to expand your base — they cost materials and require upkeep."

msgid "ui.tutorial.events"
msgstr "Each morning an event may appear — read carefully and pick the best response."

msgid "ui.tutorial.scavenge"
msgstr "Scavenging yields rare supplies but burns fuel and exposes you to risk."

msgid "ui.tutorial.members"
msgstr "Member conditions change over time — watch injuries and morale closely."

msgid "ui.tutorial.save"
msgstr "Save often. There are no do-overs in the apocalypse."

msgid "ui.tutorial.endings"
msgstr "Your decisions shape your base's ending. Spend every resource wisely."


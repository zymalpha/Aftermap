# ui.tutorial.*
msgid "ui.tutorial.welcome"
msgstr "欢迎来到末日坐标。基地是你的避难所，每一天都要做出选择。"

msgid "ui.tutorial.resources"
msgstr "关注顶部资源栏：食物、饮水、燃料和士气每天都会消耗。"

msgid "ui.tutorial.facility"
msgstr "建造设施可以扩展基地功能，消耗材料并需要日常维护。"

msgid "ui.tutorial.events"
msgstr "每天清晨会有事件出现——阅读描述并选择最合适的应对方案。"

msgid "ui.tutorial.scavenge"
msgstr "外出搜寻可获得稀有物资，但会消耗燃料并可能遭遇风险。"

msgid "ui.tutorial.members"
msgstr "幸存者的状态会随时间变化，记得关注伤病和士气。"

msgid "ui.tutorial.save"
msgstr "记得定期存档——末日里没有后悔药。"

msgid "ui.tutorial.endings"
msgstr "你的选择将决定基地的最终结局。善用每一份资源。"

